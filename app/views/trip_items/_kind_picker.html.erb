<%# Two-level kind picker.
    Locals:
      selected — current kind string (e.g. "flight")
      form     — form builder (only required when mode: :form)
      mode     — :view or :form
%>
<% mode        ||= :view %>
<% primary_key   = trip_item_primary_key(selected.to_s)  # "move" for any transport kind %>
<% is_transport  = TripItem::TRANSPORT_KINDS.include?(selected.to_s) %>

<% primary_keys  = %w[stay eat move do shop other] %>
<% transport_keys = %w[flight car train ferry other] %>

<% if mode == :form %>

  <%# ── FORM MODE — Stimulus-driven two-level picker ── %>
  <div data-controller="kind-picker" class="flex flex-col gap-2">

    <%# Hidden field that holds the real stored value %>
    <input type="hidden" name="trip_item[kind]"
           value="<%= selected %>"
           data-kind-picker-target="kindInput">

    <%# ── Transport sub-row — hidden until Move is selected ── %>
    <div data-kind-picker-target="transportPanel"
         <%= is_transport ? "" : 'hidden' %>
         class="grid grid-cols-5 rounded-2xl border border-primary/30 bg-primary/5 overflow-hidden">
      <% transport_keys.each_with_index do |key, i| %>
        <% is_last = i == transport_keys.size - 1 %>
        <button type="button"
                data-kind-picker-target="transportBtn"
                data-kind-key="<%= key %>"
                data-action="click->kind-picker#selectTransport"
                <%= (selected.to_s == key && is_transport) ? "data-active=true" : "" %>
                class="flex flex-col items-center justify-center gap-1.5 py-3.5 transition-colors
                       text-base-content/35 hover:bg-primary/10
                       data-[active]:bg-primary/20 data-[active]:text-primary
                       <%= is_last ? "" : "border-r border-primary/15" %>">
          <%= inline_svg(TripItemsHelper::TRANSPORT_SVG[key], css_class: "h-6 w-6") %>
          <span class="text-[10px] font-medium leading-none"><%= TripItemsHelper::TRANSPORT_LABELS[key] %></span>
        </button>
      <% end %>
    </div>

    <%# ── Primary row — always visible ── %>
    <div class="grid grid-cols-6 rounded-2xl border border-base-content/10 overflow-hidden">
      <% primary_keys.each_with_index do |key, i| %>
        <% is_last  = i == primary_keys.size - 1 %>
        <% active   = key == primary_key %>
        <button type="button"
                data-kind-picker-target="primaryBtn"
                data-kind-key="<%= key %>"
                data-action="click->kind-picker#selectPrimary"
                <%= active ? "data-active=true" : "" %>
                class="flex flex-col items-center justify-center gap-1.5 py-4 transition-colors
                       text-base-content/35 hover:bg-base-300/60
                       data-[active]:bg-primary/20 data-[active]:text-primary
                       <%= is_last ? "" : "border-r border-base-content/10" %>">
          <% if key == "move" %>
            <%# Default walking-man icon — hidden when a transport type is already selected %>
            <span data-kind-picker-target="moveDefaultIcon" <%= is_transport ? "hidden" : "" %>>
              <%= inline_svg("Move.svg", css_class: "h-6 w-6") %>
            </span>
            <%# One icon per transport kind — JS reveals the matching one after selection %>
            <% TripItemsHelper::TRANSPORT_SVG.except("other").each do |tk, svg_file| %>
              <span data-kind-picker-target="moveTransportIcon" data-kind="<%= tk %>"
                    <%= (is_transport && selected.to_s == tk) ? "" : "hidden" %>>
                <%= inline_svg(svg_file, css_class: "h-6 w-6") %>
              </span>
            <% end %>
          <% else %>
            <%= inline_svg(TripItemsHelper::PRIMARY_SVG[key], css_class: "h-6 w-6") %>
          <% end %>
          <span class="text-[10px] font-medium leading-none"><%= TripItemsHelper::PRIMARY_LABELS[key] %></span>
        </button>
      <% end %>
    </div>

  </div>

<% else %>

  <%# ── VIEW MODE — single data field showing the selected kind ── %>
  <div class="px-3 py-2.5 rounded-xl bg-base-300/20 border border-base-content/5">
    <p class="dp-label">Type</p>
    <div class="flex items-center gap-2 mt-0.5">
      <span class="text-base-content/50">
        <%= inline_svg(TripItemsHelper::KIND_SVG[selected.to_s] || "Do.svg", css_class: "h-4 w-4") %>
      </span>
      <p class="text-xs font-semibold text-base-content leading-tight">
        <%= TripItemsHelper::KIND_LABELS[selected.to_s] || selected.to_s.humanize %>
      </p>
    </div>
  </div>

<% end %>
