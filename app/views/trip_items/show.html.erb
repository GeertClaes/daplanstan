<% content_for :hide_navbar, true %>
<% content_for :main_class, "flex flex-col overflow-hidden" %>

<%# ── Nav band ── %>
<div class="h-14 shrink-0 max-w-sm mx-auto w-full px-4 flex items-center justify-between">

  <%= link_to trip_path(@trip, tab: "itinerary"),
        class: "flex items-center gap-2 bg-base-300/70 backdrop-blur-sm text-base-content/70
                hover:text-base-content hover:bg-base-300 px-4 h-9 rounded-full
                text-xs font-medium transition-colors",
        data: { turbo_direction: "back" } do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
    </svg>
    <%= @item_index %> of <%= @item_count %>
  <% end %>

  <span class="flex items-center gap-1.5 bg-base-300/70 backdrop-blur-sm text-base-content/50 px-3 h-9 rounded-full text-xs font-medium">
    <%= trip_item_kind_icon(@item.kind, css_class: "h-3.5 w-3.5") %>
    Itinerary
  </span>

  <div class="flex items-center bg-base-300/70 backdrop-blur-sm rounded-full overflow-hidden">
    <%= link_to @prev_item_id ? trip_trip_item_path(@trip, @prev_item_id) : "#",
          class: "flex items-center justify-center w-10 h-9 transition-colors
                  #{@prev_item_id ? "hover:bg-base-300 text-base-content/70 hover:text-base-content" : "text-base-content/20 cursor-not-allowed"}",
          title: "Previous",
          data: { turbo_direction: "prev" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
      </svg>
    <% end %>
    <div class="w-px h-5 bg-base-content/10"></div>
    <%= link_to @next_item_id ? trip_trip_item_path(@trip, @next_item_id) : "#",
          class: "flex items-center justify-center w-10 h-9 transition-colors
                  #{@next_item_id ? "hover:bg-base-300 text-base-content/70 hover:text-base-content" : "text-base-content/20 cursor-not-allowed"}",
          title: "Next",
          data: { turbo_direction: "next" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    <% end %>
  </div>

</div>

<%# ── Card ── %>
<div class="flex-1 min-h-0 px-4 pb-4">
  <div class="max-w-sm mx-auto h-full bg-base-200 border border-base-content/10 rounded-3xl
              overflow-visible flex flex-col">

    <%# ── TOP SECTION: name + status ── %>
    <div class="px-5 pt-5 pb-4 shrink-0">
      <p class="text-xl font-bold text-base-content leading-tight truncate"><%= @item.name %></p>
      <p class="text-xs font-semibold mt-1 <%= @item.confirmed? ? "text-primary" : "text-base-content/35" %>">
        <%= @item.confirmed? ? "Confirmed" : "Idea" %>
      </p>
    </div>

    <%# ── PERFORATION 1 ── %>
    <div class="relative flex items-center h-5 shrink-0">
      <div class="absolute -left-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
      <div class="flex-1 border-t-2 border-dashed border-base-content/15 mx-3"></div>
      <div class="absolute -right-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
    </div>

    <%# ── MIDDLE SECTION ── %>
    <div class="flex-1 min-h-0 overflow-y-auto px-5 py-4 space-y-4">

      <%# Kind picker (view mode) %>
      <%= render "kind_picker", selected: @item.kind, mode: :view %>

      <%# When / Until %>
      <% if @item.when_label %>
        <div class="grid grid-cols-2 gap-2">
          <div class="px-3 py-2.5 rounded-xl bg-base-300/20 border border-base-content/5">
            <p class="dp-label">When</p>
            <p class="text-xs font-semibold text-base-content leading-tight mt-0.5"><%= @item.when_label %></p>
          </div>
          <% if @item.ends_at && @item.ends_at.to_date != @item.starts_at.to_date %>
            <div class="px-3 py-2.5 rounded-xl bg-base-300/20 border border-base-content/5">
              <p class="dp-label">Until</p>
              <p class="text-xs font-semibold text-base-content leading-tight mt-0.5">
                <%= @item.ends_at.strftime("%-d %b %Y") %>
              </p>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# Address %>
      <% if @item.address.present? %>
        <div class="px-3 py-2.5 rounded-xl bg-base-300/20 border border-base-content/5">
          <p class="dp-label">Address</p>
          <p class="text-xs text-base-content/70 leading-snug mt-0.5"><%= @item.address %></p>
        </div>
      <% end %>

      <%# Amount %>
      <% if @item.amount.present? %>
        <div class="px-3 py-2.5 rounded-xl bg-base-300/20 border border-base-content/5">
          <p class="dp-label">Estimated cost</p>
          <p class="text-lg font-bold font-mono text-accent leading-tight mt-0.5">
            <%= number_with_precision(@item.amount, precision: 2) %>
            <span class="text-sm font-sans font-normal text-base-content/40 ml-1"><%= @item.currency %></span>
          </p>
        </div>
      <% end %>

      <%# Confirmation ref + source email ── boarding-pass ticket fields %>
      <div class="grid grid-cols-2 gap-2">

        <%# Confirmation ref %>
        <div class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl bg-base-300/20 border border-base-content/5">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          <div class="min-w-0">
            <p class="dp-label">Ref</p>
            <% if @display_ref.present? %>
              <p class="text-xs font-mono font-semibold text-base-content/70 leading-tight mt-0.5 truncate"><%= @display_ref %></p>
            <% else %>
              <p class="text-xs text-base-content/25 leading-tight mt-0.5">No ref</p>
            <% end %>
          </div>
        </div>

        <%# Source email %>
        <% if @item.inbox_item_id %>
          <%= link_to trip_inbox_item_path(@trip, @item.inbox_item_id),
                class: "flex items-center gap-2.5 px-3 py-2.5 rounded-xl
                        bg-primary/10 border border-primary/20
                        hover:bg-primary/20 transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <div class="min-w-0">
              <p class="dp-label">Source</p>
              <p class="text-xs font-semibold text-primary leading-tight mt-0.5">Email ›</p>
            </div>
          <% end %>
        <% else %>
          <div class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl
                      bg-base-300/20 border border-base-content/5">
            <span class="relative shrink-0 w-4 h-4 text-base-content/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <svg class="absolute inset-0 w-full h-full" viewBox="0 0 24 24">
                <line x1="3" y1="21" x2="21" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
            <div class="min-w-0">
              <p class="dp-label opacity-40">Source</p>
              <p class="text-xs text-base-content/25 leading-tight mt-0.5">No email</p>
            </div>
          </div>
        <% end %>

      </div>

      <%# Notes %>
      <% if @item.notes.present? %>
        <div class="px-3 py-2.5 rounded-xl bg-base-300/20 border border-base-content/5">
          <p class="dp-label">Notes</p>
          <p class="text-xs text-base-content/70 leading-snug mt-0.5 whitespace-pre-wrap"><%= @item.notes %></p>
        </div>
      <% end %>

      <%# Linked expense %>
      <% if @display_expense %>
        <div class="grid grid-cols-2">
          <%= link_to trip_expense_path(@trip, @display_expense),
                class: "flex items-center gap-2.5 px-3 py-2.5 rounded-xl
                        bg-primary/10 border border-primary/20
                        hover:bg-primary/20 transition-colors",
                data: { turbo_direction: "forward" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9"/>
              <path stroke-linecap="round" d="M14.5 9a4 4 0 100 6M8.5 11h5M8.5 13h5"/>
            </svg>
            <div class="min-w-0">
              <p class="dp-label">Expense</p>
              <p class="text-xs font-semibold text-primary leading-tight mt-0.5">
                <%= number_with_precision(@display_expense.amount, precision: 2) %> <%= @display_expense.currency %> ›
              </p>
            </div>
          <% end %>
        </div>
      <% end %>

    </div>

    <%# ── PERFORATION 2 ── %>
    <div class="relative flex items-center h-5 shrink-0">
      <div class="absolute -left-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
      <div class="flex-1 border-t-2 border-dashed border-base-content/15 mx-3"></div>
      <div class="absolute -right-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
    </div>

    <%# ── BOTTOM SECTION: action buttons ── %>
    <div class="px-5 py-4 shrink-0 flex items-center justify-between">

      <%# Delete — red circle %>
      <%= button_to trip_trip_item_path(@trip, @item), method: :delete,
            data: { turbo_confirm: "Remove this item?" },
            class: "w-12 h-12 rounded-full bg-error/15 text-error hover:bg-error/25
                    transition-colors flex items-center justify-center shrink-0" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      <% end %>

      <%# Action pill: Edit | Add expense (if none yet) %>
      <div class="flex items-center bg-base-100/60 backdrop-blur-sm rounded-full overflow-hidden border border-base-content/8">

        <%# Edit %>
        <%= link_to edit_trip_trip_item_path(@trip, @item),
              class: "flex flex-col items-center justify-center gap-0.5 px-4 h-14
                      text-base-content/60 hover:text-base-content hover:bg-base-300/60 transition-colors",
              data: { turbo_direction: "forward" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
          </svg>
          <span class="text-[9px] font-medium leading-none">Edit</span>
        <% end %>

        <div class="w-px h-6 bg-base-content/10"></div>

        <% if @display_expense %>
          <%# View linked expense %>
          <%= link_to trip_expense_path(@trip, @display_expense),
                class: "flex flex-col items-center justify-center gap-0.5 px-4 h-14
                        text-base-content/50 hover:text-base-content hover:bg-base-300/60 transition-colors",
                data: { turbo_direction: "forward" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9"/>
              <path stroke-linecap="round" d="M14.5 9a4 4 0 100 6M8.5 11h5M8.5 13h5"/>
            </svg>
            <span class="text-[9px] font-medium leading-none">Expense</span>
          <% end %>
        <% else %>
          <%# Add expense %>
          <%= link_to to_expense_trip_trip_item_path(@trip, @item),
                class: "flex flex-col items-center justify-center gap-0.5 px-4 h-14
                        text-base-content/60 hover:text-accent hover:bg-accent/10 transition-colors",
                data: { turbo_direction: "forward" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9"/>
              <path stroke-linecap="round" d="M14.5 9a4 4 0 100 6M8.5 11h5M8.5 13h5"/>
            </svg>
            <span class="text-[9px] font-medium leading-none">Expense</span>
          <% end %>
        <% end %>

      </div>

    </div>

  </div>
</div>
