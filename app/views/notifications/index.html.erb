<% content_for :hide_navbar, true %>
<% content_for :main_class, "overflow-y-auto" %>

<div class="max-w-lg mx-auto px-4 pb-8"
     style="padding-top: max(1.25rem, env(safe-area-inset-top))"
     data-controller="pull-to-refresh">

  <%# ── Header ── %>
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Notifications</h1>
    <%= link_to trips_path,
          class: "w-9 h-9 rounded-full bg-base-300/70 backdrop-blur-sm
                  flex items-center justify-center text-base-content/60
                  hover:bg-base-300 hover:text-base-content transition-colors",
          title: "Close",
          data: { turbo_direction: "back" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    <% end %>
  </div>

  <% if @items.empty? %>

    <%# ── Empty state ── %>
    <div class="flex flex-col items-center justify-center py-24 text-center">
      <div class="w-16 h-16 rounded-full bg-success/10 flex items-center justify-center mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="text-base font-semibold text-base-content">All caught up</p>
      <p class="text-sm text-base-content/40 mt-1">No emails waiting for review</p>
    </div>

  <% else %>

    <%# ── Notification list ── %>
    <div class="space-y-2">
      <% @items.each do |item| %>
        <%= link_to trip_inbox_item_path(item.trip, item, back: "notifications"),
              class: "block bg-base-200 border border-base-content/8 rounded-2xl px-4 py-3.5
                      hover:bg-base-300/50 transition-colors",
              data: { turbo_direction: "forward" } do %>
          <div class="flex items-center gap-3">

            <%# Sender avatar %>
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold shrink-0
                        <%= item.pending_review? ? "bg-primary/15 text-primary" : "bg-warning/15 text-warning" %>">
              <%= (item.from_name.presence || item.from_email).first.upcase %>
            </div>

            <%# Content %>
            <div class="flex-1 min-w-0">
              <p class="text-[10px] font-semibold text-primary/60 uppercase tracking-wide mb-0.5">
                <%= item.trip.title %>
              </p>
              <p class="text-sm font-semibold text-base-content leading-snug truncate">
                <%= item.subject.presence || "(no subject)" %>
              </p>
              <p class="text-xs text-base-content/40 mt-0.5 truncate">
                <%= item.from_name.presence || item.from_email %> &middot; <%= time_ago_in_words(item.received_at) %> ago
              </p>
            </div>

            <%# Status + chevron %>
            <div class="flex items-center gap-2 shrink-0">
              <% if item.pending_approval? %>
                <span class="text-[10px] font-medium text-warning bg-warning/10 px-2 py-0.5 rounded-full whitespace-nowrap">
                  Unknown sender
                </span>
              <% else %>
                <span class="w-2 h-2 rounded-full bg-primary"></span>
              <% end %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </div>

          </div>
        <% end %>
      <% end %>
    </div>

  <% end %>

</div>
