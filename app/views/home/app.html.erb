      </svg>
    </div>

    <%# Brand name %>
    <h1 class="text-5xl font-extrabold tracking-tight mb-4">
      <span style="color:#4ECDC4">DaPlan</span><span style="color:#FF5F5F">Stan</span>
    </h1>

    <%# Tagline %>
    <p class="text-lg mb-2" style="color: rgba(255,255,255,0.75)">
      Trip planning for people who actually travel.
    </p>
    <p class="text-sm mb-10" style="color: rgba(255,255,255,0.35)">
      Forward booking emails &middot; Pin places on a map &middot; Track what you spend
    </p>

    <%# Sign in with Google %>
    <form action="/auth/google_oauth2" method="post" data-turbo="false" class="w-full max-w-xs">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <button type="submit"
              class="w-full flex items-center justify-center gap-3 font-semibold text-base
                     rounded-2xl px-6 py-4 transition-all"
              style="background: #4ECDC4; color: #0a1628;
                     box-shadow: 0 0 32px rgba(78,205,196,0.35), 0 4px 16px rgba(0,0,0,0.4);"
              onmouseover="this.style.boxShadow='0 0 48px rgba(78,205,196,0.5), 0 4px 16px rgba(0,0,0,0.4)'"
              onmouseout="this.style.boxShadow='0 0 32px rgba(78,205,196,0.35), 0 4px 16px rgba(0,0,0,0.4)'">
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue with Google
      </button>
    </form>

  </div>

  <%# ── Footer ── %>
  <div class="relative pb-10 text-center">
    <p class="text-xs space-x-3" style="color: rgba(255,255,255,0.35)">
      <%= link_to "Privacy", privacy_path, class: "hover:underline" %>
      <%= link_to "Terms", terms_path, class: "hover:underline" %>
    </p>
  </div>

</div>
