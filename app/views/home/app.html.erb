<%# Full-height login page -%>
<div class="min-h-screen flex flex-col relative overflow-hidden">

  <%# Background gradients %>
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0" style="background: linear-gradient(160deg, #0a1628 0%, #0d1a2e 50%, #071018 100%)"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[500px] opacity-20 blur-3xl rounded-full"
         style="background: radial-gradient(circle, #22cbb2 0%, transparent 70%)"></div>
    <div class="absolute bottom-0 right-0 w-[300px] h-[300px] opacity-10 blur-3xl rounded-full"
         style="background: radial-gradient(circle, #FF5F5F 0%, transparent 70%)"></div>
  </div>

  <%# ── Hero ── %>
  <div class="relative flex-1 flex flex-col items-center justify-center px-6 pt-24 pb-10 text-center">

    <%# Logo with glow %>
    <div class="mb-6 relative">
      <div class="absolute inset-0 blur-2xl opacity-30 scale-75"
           style="background: radial-gradient(circle, #22cbb2 0%, transparent 70%)"></div>
