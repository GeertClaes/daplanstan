        <path d="M512.766 414.897C592.376 414.897 656.912 350.361 656.912 270.751C656.912 191.142 592.376 126.606 512.766 126.606C433.157 126.606 368.621 191.142 368.621 270.751C368.621 350.361 433.157 414.897 512.766 414.897Z" fill="white"/>
