<% content_for :hide_navbar, true %>
<% content_for :main_class, "flex flex-col overflow-hidden" %>

<% inbox_item_id = @expense.inbox_item_id %>

<%# ── Nav band (h-14 = 56px — matches the spacer in _form so cards are same size) ── %>
<div class="h-14 shrink-0 max-w-sm mx-auto w-full px-4 flex items-center justify-between">

  <%= link_to trip_path(@trip, tab: "expenses"),
        class: "flex items-center gap-2 bg-base-300/70 backdrop-blur-sm text-base-content/70
                hover:text-base-content hover:bg-base-300 px-4 h-9 rounded-full
                text-xs font-medium transition-colors",
        data: { turbo_direction: "back" } do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
    </svg>
    <%= @expense_index %> of <%= @expense_count %>
  <% end %>

  <span class="flex items-center gap-1.5 bg-base-300/70 backdrop-blur-sm text-base-content/50 px-3 h-9 rounded-full text-xs font-medium">
    <%= expense_category_icon(@expense.category, css_class: "h-3.5 w-3.5") %>
    Expense
  </span>

  <div class="flex items-center bg-base-300/70 backdrop-blur-sm rounded-full overflow-hidden">
    <%= link_to @prev_expense_id ? trip_expense_path(@trip, @prev_expense_id) : "#",
          class: "flex items-center justify-center w-10 h-9 transition-colors
                  #{@prev_expense_id ? "hover:bg-base-300 text-base-content/70 hover:text-base-content" : "text-base-content/20 cursor-not-allowed"}",
          title: "Previous",
          data: { turbo_direction: "prev" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
      </svg>
    <% end %>
    <div class="w-px h-5 bg-base-content/10"></div>
    <%= link_to @next_expense_id ? trip_expense_path(@trip, @next_expense_id) : "#",
          class: "flex items-center justify-center w-10 h-9 transition-colors
                  #{@next_expense_id ? "hover:bg-base-300 text-base-content/70 hover:text-base-content" : "text-base-content/20 cursor-not-allowed"}",
          title: "Next",
          data: { turbo_direction: "next" } do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    <% end %>
  </div>

</div>

<%# ── Card — fills remaining height, overflow-visible for punch-hole circles ── %>
<div class="flex-1 min-h-0 px-4 pb-4">
  <div class="max-w-sm mx-auto h-full bg-base-200 border border-base-content/10 rounded-3xl
              overflow-visible flex flex-col">

    <%# ── TOP SECTION: avatar + amount + status ── %>
    <div class="flex items-center gap-3 px-5 pt-5 pb-4 shrink-0">
      <div class="w-10 h-10 rounded-full overflow-hidden shrink-0 ring-2 ring-base-content/10">
        <%= image_tag @expense.paid_by.avatar(size: 64),
              alt: @expense.paid_by.name,
              class: "w-full h-full object-cover", referrerpolicy: "no-referrer" %>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-3xl font-bold font-mono leading-none <%= @expense.confirmed? ? "text-base-content/40" : "text-warning" %>">
          <%= number_with_precision(@expense.amount, precision: 2) %>
          <span class="text-base font-sans font-normal text-base-content/40 ml-1"><%= @expense.currency %></span>
        </p>
      </div>
      <p class="text-sm font-semibold shrink-0 <%= @expense.confirmed? ? "text-base-content/30" : "text-warning" %>">
        <%= @expense.confirmed? ? "Paid" : "To Settle" %>
      </p>
    </div>

    <%# ── PERFORATION 1 (punch-hole circles use bg-base-100) ── %>
    <div class="relative flex items-center h-5 shrink-0">
      <div class="absolute -left-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
      <div class="flex-1 border-t-2 border-dashed border-base-content/15 mx-3"></div>
      <div class="absolute -right-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
    </div>

    <%# ── MIDDLE SECTION ── %>
    <div class="flex-1 min-h-0 overflow-y-auto px-5 py-4 space-y-4">

      <%# Description + date %>
      <div>
        <p class="text-xl font-bold text-base-content leading-snug"><%= @expense.description %></p>
        <p class="text-sm text-base-content/40 mt-0.5"><%= relative_expense_date(@expense.expense_date) %></p>
      </div>

      <%# Category (read-only) %>
      <%= render "category_picker", selected: @expense.category, mode: :view %>

      <%# Email + receipt — boarding-pass ticket fields, always shown %>
      <div class="grid grid-cols-2 gap-2">

        <%# Email field %>
        <% if inbox_item_id %>
          <%= link_to trip_inbox_item_path(@trip, inbox_item_id),
                class: "flex items-center gap-2.5 px-3 py-2.5 rounded-xl
                        bg-primary/10 border border-primary/20
                        hover:bg-primary/20 transition-colors group" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <div class="min-w-0">
              <p class="dp-label">Source</p>
              <p class="text-xs font-semibold text-primary leading-tight mt-0.5">Email ›</p>
            </div>
          <% end %>
        <% else %>
          <div class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl
                      bg-base-300/20 border border-base-content/5">
            <span class="relative shrink-0 w-4 h-4 text-base-content/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <svg class="absolute inset-0 w-full h-full" viewBox="0 0 24 24">
                <line x1="3" y1="21" x2="21" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
            <div class="min-w-0">
              <p class="dp-label opacity-40">Source</p>
              <p class="text-xs text-base-content/25 leading-tight mt-0.5">No email</p>
            </div>
          </div>
        <% end %>

        <%# Receipt field %>
        <% if @expense.receipt.attached? %>
          <a href="<%= url_for(@expense.receipt) %>" target="_blank"
             class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl
                    bg-primary/10 border border-primary/20
                    hover:bg-primary/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div class="min-w-0">
              <p class="dp-label">Receipt</p>
              <p class="text-xs font-semibold text-primary leading-tight mt-0.5">Photo ›</p>
            </div>
          </a>
        <% else %>
          <div class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl
                      bg-base-300/20 border border-base-content/5">
            <span class="relative shrink-0 w-4 h-4 text-base-content/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-full h-full" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <svg class="absolute inset-0 w-full h-full" viewBox="0 0 24 24">
                <line x1="3" y1="21" x2="21" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
            <div class="min-w-0">
              <p class="dp-label opacity-40">Receipt</p>
              <p class="text-xs text-base-content/25 leading-tight mt-0.5">No photo</p>
            </div>
          </div>
        <% end %>

      </div>

    </div>

    <%# ── PERFORATION 2 ── %>
    <div class="relative flex items-center h-5 shrink-0">
      <div class="absolute -left-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
      <div class="flex-1 border-t-2 border-dashed border-base-content/15 mx-3"></div>
      <div class="absolute -right-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
    </div>

    <%# ── BOTTOM SECTION: action buttons inside the card ── %>
    <div class="px-5 py-4 shrink-0 flex items-center justify-between">

      <%# Delete — red circle %>
      <%= button_to trip_expense_path(@trip, @expense), method: :delete,
            data: { turbo_confirm: "Delete this expense?" },
            class: "w-12 h-12 rounded-full bg-error/15 text-error hover:bg-error/25
                    transition-colors flex items-center justify-center shrink-0" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      <% end %>

      <%# Edit / Receipt / Settle pill %>
      <div class="flex items-center bg-base-100/60 backdrop-blur-sm rounded-full overflow-hidden border border-base-content/8">

        <%# Edit %>
        <%= link_to edit_trip_expense_path(@trip, @expense),
              class: "flex flex-col items-center justify-center gap-0.5 px-4 h-14
                      text-base-content/60 hover:text-base-content hover:bg-base-300/60 transition-colors",
              data: { turbo_direction: "forward" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
          </svg>
          <span class="text-[9px] font-medium leading-none">Edit</span>
        <% end %>

        <div class="w-px h-6 bg-base-content/10"></div>

        <%# Receipt — attach photo %>
        <%= form_with url: trip_expense_path(@trip, @expense), method: :patch,
              data: { controller: "receipt" }, class: "contents" do |f| %>
          <label class="flex flex-col items-center justify-center gap-0.5 px-4 h-14
                        text-base-content/60 hover:text-base-content hover:bg-base-300/60
                        transition-colors cursor-pointer">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-[9px] font-medium leading-none">Receipt</span>
            <%= f.file_field :receipt, accept: "image/*", capture: "environment", class: "hidden",
                  data: { receipt_target: "input", action: "change->receipt#submitForm" } %>
          </label>
        <% end %>

        <div class="w-px h-6 bg-base-content/10"></div>

        <%# Settle toggle — mark paid / unmark %>
        <%= button_to confirm_trip_expense_path(@trip, @expense), method: :patch,
              class: "flex flex-col items-center justify-center gap-0.5 px-4 h-14 transition-colors
                      #{@expense.confirmed? ? "text-error/70 hover:text-error hover:bg-error/10" : "text-success/70 hover:text-success hover:bg-success/10"}" do %>
          <% if @expense.confirmed? %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9"/>
              <path stroke-linecap="round" d="M14.5 9a4 4 0 100 6M8.5 11h5M8.5 13h5"/>
              <line x1="4" y1="4" x2="20" y2="20" stroke-linecap="round"/>
            </svg>
            <span class="text-[9px] font-medium leading-none">Paid</span>
          <% else %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="9"/>
              <path stroke-linecap="round" d="M14.5 9a4 4 0 100 6M8.5 11h5M8.5 13h5"/>
            </svg>
            <span class="text-[9px] font-medium leading-none">Settle</span>
          <% end %>
        <% end %>

      </div>

    </div>

  </div>
</div>
