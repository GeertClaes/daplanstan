<%# Hide global navbar — the card IS the screen %>
<% content_for :hide_navbar, true %>
<% content_for :main_class, "flex flex-col overflow-hidden" %>

<% inbox_item_id = expense.inbox_item_id %>

<%= form_with model: [@trip, expense], data: { controller: "receipt" },
      class: "flex-1 flex flex-col overflow-hidden" do |f| %>
  <%= f.hidden_field :trip_item_id if expense.trip_item_id.present? %>

  <%# ── Spacer (h-14 = 56px — matches nav band on show so cards are identical size) ── %>
  <div class="h-14 shrink-0 max-w-sm mx-auto w-full px-4 flex items-center justify-between">
    <div class="flex gap-2 flex-wrap">
      <% expense.errors.full_messages.each do |msg| %>
        <span class="text-xs text-error font-medium"><%= msg %></span>
      <% end %>
    </div>
    <span class="flex items-center gap-1.5 bg-base-300/70 backdrop-blur-sm text-base-content/50 px-3 py-1.5 rounded-full text-xs font-medium shrink-0">
      <%= expense_category_icon(expense.category, css_class: "h-3.5 w-3.5") %>
      Expense
    </span>
  </div>

  <%# ── Card — same dimensions as show page ── %>
  <div class="flex-1 min-h-0 px-4 pb-4">
    <div class="max-w-sm mx-auto h-full bg-base-200 border border-base-content/10 rounded-3xl
                overflow-visible flex flex-col">

      <%# ── TOP SECTION: amount + currency ── %>
      <div class="px-6 pt-5 pb-4 shrink-0 flex items-end gap-3">
        <%= f.number_field :amount, step: "0.01", placeholder: "0.00",
              value: expense.amount.present? ? "%.2f" % expense.amount : nil,
              class: "w-0 flex-1 text-4xl font-bold font-mono text-accent bg-transparent
                      border-0 border-b border-base-content/15 rounded-none pb-1
                      focus:outline-none focus:border-primary placeholder:text-accent/30",
              autofocus: expense.new_record? %>
        <%= f.select :currency,
              ExpensesHelper::COMMON_CURRENCIES.map { |c| [c, c] },
              { selected: expense.currency.presence || "EUR" },
              class: "shrink-0 w-20 text-sm font-mono text-base-content/60 bg-transparent
                      border-0 border-b border-base-content/15 rounded-none pb-1.5 mb-0.5
                      focus:outline-none focus:border-primary appearance-none cursor-pointer" %>
      </div>

      <%# ── PERFORATION 1 ── %>
      <div class="relative flex items-center h-5 shrink-0">
        <div class="absolute -left-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
        <div class="flex-1 border-t-2 border-dashed border-base-content/15 mx-3"></div>
        <div class="absolute -right-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
      </div>

      <%# ── MIDDLE SECTION ── %>
      <div class="flex-1 min-h-0 overflow-y-auto px-5 py-4 flex flex-col gap-4">

        <%# Description %>
        <%= f.text_field :description, placeholder: "What was it for?",
              class: "w-full text-base text-base-content bg-transparent
                      border-0 border-b border-base-content/15 rounded-none px-0 pb-2
                      focus:outline-none focus:border-primary placeholder:text-base-content/25" %>

        <%# Date %>
        <%= f.date_field :expense_date,
              class: "w-full text-sm text-base-content/70 bg-transparent
                      border-0 border-b border-base-content/15 rounded-none px-0 pb-2
                      focus:outline-none focus:border-primary" %>

        <%# Category picker %>
        <div class="pt-1">
          <%= render "category_picker", selected: expense.category, mode: :form, form: f %>
        </div>

        <%# Paid by — avatar tiles %>
        <div>
          <p class="dp-label mb-2">Paid by</p>
          <div class="flex gap-2 flex-wrap">
          <% members.each do |member| %>
            <label class="cursor-pointer">
              <input type="radio" name="expense[paid_by_traveler_id]"
                     value="<%= member.traveler_id %>"
                     class="sr-only peer"
                     <%= "checked" if expense.paid_by_traveler_id.to_s == member.traveler_id.to_s %>>
              <div class="flex flex-col items-center gap-1 p-1.5 rounded-2xl border-2 border-transparent
                           peer-checked:border-primary peer-checked:bg-primary/10 transition-all">
                <%= image_tag member.traveler.avatar(size: 64),
                      class: "w-12 h-12 rounded-full object-cover",
                      referrerpolicy: "no-referrer" %>
                <span class="text-[10px] font-medium text-base-content/50 leading-none">
                  <%= member.traveler.name.split(" ").first %>
                </span>
              </div>
            </label>
          <% end %>
          </div>
        </div>

        <%# Source email link (if linked) %>
        <% if inbox_item_id %>
          <%= link_to trip_inbox_item_path(@trip, inbox_item_id),
                class: "flex items-center gap-2 text-base-content/30 hover:text-primary transition-colors text-xs" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            View source email
          <% end %>
        <% end %>

        <%# Receipt preview %>
        <% if expense.receipt.attached? %>
          <%= image_tag url_for(expense.receipt),
                class: "w-full max-h-28 object-contain rounded-xl", alt: "Receipt" %>
        <% end %>
        <img data-receipt-target="preview" class="hidden w-full max-h-28 object-contain rounded-xl" alt="">

      </div>

      <%# ── PERFORATION 2 ── %>
      <div class="relative flex items-center h-5 shrink-0">
        <div class="absolute -left-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
        <div class="flex-1 border-t-2 border-dashed border-base-content/15 mx-3"></div>
        <div class="absolute -right-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
      </div>

      <%# ── BOTTOM SECTION: cancel + save ── %>
      <div class="px-5 py-4 shrink-0 flex items-center justify-between">

        <%# Cancel — grey X circle %>
        <%= link_to (expense.new_record? ? trip_path(@trip, tab: "expenses") : trip_expense_path(@trip, expense)),
              class: "w-12 h-12 rounded-full bg-base-300/80 text-base-content/50
                      hover:text-base-content hover:bg-base-300 transition-colors
                      flex items-center justify-center",
              data: { turbo_direction: "back" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        <% end %>

        <%# Save — teal checkmark circle %>
        <%= f.button type: "submit",
              class: "w-12 h-12 rounded-full bg-primary text-primary-content
                      hover:opacity-90 transition-opacity flex items-center justify-center shadow-lg" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        <% end %>

      </div>

    </div>
  </div>

<% end %>
