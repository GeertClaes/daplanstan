<nav class="sm:hidden flex border-t dp-nav-bar shrink-0"
     style="padding-bottom: env(safe-area-inset-bottom)">

  <button class="flex-1 flex flex-col items-center pt-2 pb-3 gap-0.5 text-[11px] font-medium transition-colors text-base-content/40"
          data-tab="itinerary" data-nav-scope="mobile"
          data-action="click->trip-nav#switch" data-trip-nav-target="navItem">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
    </svg>
    Itinerary
  </button>

  <button class="flex-1 flex flex-col items-center pt-2 pb-3 gap-0.5 text-[11px] font-medium transition-colors text-base-content/40"
          data-tab="expenses" data-nav-scope="mobile"
          data-action="click->trip-nav#switch" data-trip-nav-target="navItem">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
    </svg>
    Expenses
  </button>

  <button class="relative flex-1 flex flex-col items-center pt-2 pb-3 gap-0.5 text-[11px] font-medium transition-colors text-base-content/40"
          data-tab="trip" data-nav-scope="mobile"
          data-action="click->trip-nav#switch" data-trip-nav-target="navItem">
    <% if @inbox_pending_count > 0 %>
      <span class="absolute top-1.5 right-[calc(50%-14px)] w-2.5 h-2.5 rounded-full bg-error border-2 border-base-100"></span>
    <% end %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <rect x="3" y="8" width="18" height="13" rx="2"/>
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 8V6a4 4 0 018 0v2"/>
      <line x1="7" y1="21" x2="7" y2="19" stroke-linecap="round" stroke-width="2.5"/>
      <line x1="17" y1="21" x2="17" y2="19" stroke-linecap="round" stroke-width="2.5"/>
      <circle cx="7" cy="21" r="1" fill="currentColor" stroke="none"/>
      <circle cx="17" cy="21" r="1" fill="currentColor" stroke="none"/>
    </svg>
    Trip
  </button>

</nav>
