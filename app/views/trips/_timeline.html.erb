<%# timeline: ActiveRecord collection of TripItems, trip: Trip %>

<% if trip_items.empty? %>
  <div class="text-center text-base-content/40 py-12 px-4">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto mb-3 text-base-content/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
    </svg>
    <p class="text-sm">No stops yet.</p>
    <p class="text-xs mt-1 text-base-content/30">Forward confirmation emails or add a stop manually.</p>
  </div>
<% else %>
  <%
    confirmed_items = trip_items.select(&:confirmed?)
    idea_items      = trip_items.select(&:idea?)
    present_kinds   = trip_items.map(&:kind).uniq
  %>

  <div data-controller="timeline" class="flex flex-col min-h-0">

    <%# ── Filter bar — only shown when 2+ kinds present ── %>
    <% if present_kinds.size > 1 %>
      <div class="flex gap-1.5 px-3 py-2.5 border-b border-base-content/8 overflow-x-auto shrink-0 scrollbar-none">
        <button class="shrink-0 text-[11px] font-semibold px-3 py-1 rounded-full bg-primary text-primary-content transition-colors"
                data-kind="all"
                data-timeline-target="filterBtn"
                data-action="click->timeline#filter">
          All
        </button>
        <% TripItem.kinds.keys.each do |kind| %>
          <% next unless present_kinds.include?(kind) %>
          <button class="shrink-0 text-[11px] font-semibold px-3 py-1 rounded-full bg-base-300 text-base-content/60 transition-colors"
                  data-kind="<%= kind %>"
                  data-timeline-target="filterBtn"
                  data-action="click->timeline#filter">
            <%= trip_item_kind_label(kind) %>
          </button>
        <% end %>
      </div>
    <% end %>

    <%# ── Scrollable list ── %>
    <div class="flex-1 overflow-y-auto pb-6 px-2">

      <%# ── Confirmed section ── %>
      <% if confirmed_items.any? %>
        <% grouped = confirmed_items.group_by { |i| i.starts_at&.to_date } %>
        <% sorted_dates = grouped.keys.compact.sort + (grouped.key?(nil) ? [nil] : []) %>

        <div class="pt-2 space-y-0.5">
          <% sorted_dates.each do |date| %>
            <div data-timeline-target="dateGroup">
              <div class="px-3 pt-3 pb-1">
                <p class="text-[10px] font-semibold uppercase tracking-wider text-base-content/30">
                  <%= date ? date.strftime("%-d %B") : "Date TBD" %>
                </p>
              </div>
              <% grouped[date].each do |item| %>
                <%= render "trip_items/item_row", item: item, trip: trip %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <%# ── Ideas divider ── %>
      <% if idea_items.any? %>
        <div class="relative flex items-center gap-3 px-3 py-4 mt-2">
          <div class="flex-1 h-px bg-base-content/10"></div>
          <span class="flex items-center gap-1.5 text-[10px] font-semibold uppercase tracking-widest text-base-content/30 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
            </svg>
            Ideas
          </span>
          <div class="flex-1 h-px bg-base-content/10"></div>
        </div>

        <% grouped = idea_items.group_by { |i| i.starts_at&.to_date } %>
        <% sorted_dates = grouped.keys.compact.sort + (grouped.key?(nil) ? [nil] : []) %>

        <div class="space-y-0.5">
          <% sorted_dates.each do |date| %>
            <div data-timeline-target="dateGroup">
              <% if date %>
                <div class="px-3 pt-3 pb-1">
                  <p class="text-[10px] font-semibold uppercase tracking-wider text-base-content/30">
                    <%= date.strftime("%-d %B") %>
                  </p>
                </div>
              <% end %>
              <% grouped[date].each do |item| %>
                <%= render "trip_items/item_row", item: item, trip: trip %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>
<% end %>
