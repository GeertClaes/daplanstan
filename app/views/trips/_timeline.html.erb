<%# timeline: ActiveRecord collection of TripItems, trip: Trip %>

<% if trip_items.empty? %>
  <div class="text-center text-base-content/40 py-12 px-4">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto mb-3 text-base-content/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
    </svg>
    <p class="text-sm">No stops yet.</p>
    <p class="text-xs mt-1 text-base-content/30">Forward confirmation emails or add a stop manually.</p>
  </div>
<% else %>
  <%
    present_kinds    = trip_items.map(&:kind).uniq
    present_statuses = trip_items.map(&:status).uniq
    dated_items      = trip_items.select { |i| i.starts_at.present? }
    undated_items    = trip_items.select { |i| i.starts_at.nil? }
    grouped          = dated_items.group_by { |i| i.starts_at.to_date }
    sorted_dates     = grouped.keys.sort
    show_kind_filter   = present_kinds.size > 1
    show_status_filter = present_statuses.size > 1
  %>

  <div data-controller="timeline" class="flex flex-col min-h-0">

    <%# ── Filter bar ── %>
    <% if show_kind_filter || show_status_filter %>
      <div class="flex items-center gap-1.5 px-3 py-2.5 border-b border-base-content/8 overflow-x-auto shrink-0 scrollbar-none">

        <%# Kind filter pills — icon only %>
        <% if show_kind_filter %>
          <button class="shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-primary text-primary-content transition-colors text-[10px] font-bold"
                  data-kind="all"
                  data-timeline-target="filterBtn"
                  data-action="click->timeline#filter"
                  title="All types">
            All
          </button>
          <% TripItem.kinds.keys.each do |kind| %>
            <% next unless present_kinds.include?(kind) %>
            <button class="shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-base-300 text-base-content/60 transition-colors"
                    data-kind="<%= kind %>"
                    data-timeline-target="filterBtn"
                    data-action="click->timeline#filter"
                    title="<%= trip_item_kind_label(kind) %>">
              <%= trip_item_kind_icon(kind, css_class: "h-4 w-4") %>
            </button>
          <% end %>
        <% end %>

        <%# Divider between kind and status sections %>
        <% if show_kind_filter && show_status_filter %>
          <div class="w-px h-4 bg-base-content/15 shrink-0 mx-0.5"></div>
        <% end %>

        <%# Status filter pills — idea / confirmed %>
        <% if show_status_filter %>
          <button class="shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-primary text-primary-content transition-colors"
                  data-status="all"
                  data-timeline-target="statusBtn"
                  data-action="click->timeline#filterStatus"
                  title="All statuses">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z"/>
            </svg>
          </button>
          <button class="shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-base-300 text-base-content/40 transition-colors"
                  data-status="idea"
                  data-timeline-target="statusBtn"
                  data-action="click->timeline#filterStatus"
                  title="Ideas only">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="4 2.5">
              <circle cx="12" cy="12" r="9"/>
            </svg>
          </button>
          <button class="shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-base-300 text-primary transition-colors"
                  data-status="confirmed"
                  data-timeline-target="statusBtn"
                  data-action="click->timeline#filterStatus"
                  title="Confirmed only">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </button>
        <% end %>

      </div>
    <% end %>

    <%# ── Scrollable list ── %>
    <div class="flex-1 overflow-y-auto pb-6 px-2">
      <div class="pt-2 space-y-0.5">

        <%# Dated items grouped by day %>
        <% sorted_dates.each do |date| %>
          <div data-timeline-target="dateGroup">
            <div class="px-3 pt-3 pb-1">
              <p class="text-[10px] font-semibold uppercase tracking-wider text-base-content/30">
                <%= date.strftime("%-d %B") %>
              </p>
            </div>
            <% grouped[date].each do |item| %>
              <%= render "trip_items/item_row", item: item, trip: trip %>
            <% end %>
          </div>
        <% end %>

        <%# Undated items at the end %>
        <% if undated_items.any? %>
          <div data-timeline-target="dateGroup">
            <% if sorted_dates.any? %>
              <div class="px-3 pt-3 pb-1">
                <p class="text-[10px] font-semibold uppercase tracking-wider text-base-content/30">Date TBD</p>
              </div>
            <% end %>
            <% undated_items.each do |item| %>
              <%= render "trip_items/item_row", item: item, trip: trip %>
            <% end %>
          </div>
        <% end %>

      </div>
    </div>
  </div>
<% end %>
