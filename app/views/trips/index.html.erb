<%# FAB: New Trip %>
<% content_for :fab do %>
  <%= link_to new_trip_path,
        class: "w-14 h-14 rounded-full bg-primary text-primary-content
                shadow-xl shadow-primary/30 flex items-center justify-center
                hover:opacity-90 transition-opacity",
        data: { turbo_direction: "forward" } do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
    </svg>
  <% end %>
<% end %>

<div class="max-w-2xl mx-auto px-4 py-8">

  <% if @trips.empty? %>

    <%# ── Empty state ── %>
    <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">

      <%# Illustration: stacked cards + globe %>
      <div class="relative w-40 h-40 mb-8 select-none" aria-hidden="true">
        <%# Back card %>
        <div class="absolute bottom-0 left-4 right-4 h-24 rounded-2xl rotate-[-6deg] origin-bottom"
             style="background: linear-gradient(135deg, #1e2a3f 0%, #0d9488 100%); opacity: 0.5;"></div>
        <%# Mid card %>
        <div class="absolute bottom-0 left-2 right-2 h-28 rounded-2xl rotate-[2deg] origin-bottom"
             style="background: linear-gradient(135deg, #161f2e 0%, #7c3aed 100%); opacity: 0.7;"></div>
        <%# Front card %>
        <div class="absolute bottom-0 inset-x-0 h-32 rounded-2xl flex flex-col items-center justify-center gap-1"
             style="background: linear-gradient(135deg, #161f2e 0%, #14b8a6 80%);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.25">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-white/60 text-[10px] font-semibold tracking-widest uppercase">Somewhere</span>
        </div>
      </div>

      <h1 class="text-2xl font-bold text-base-content">Plan your first trip</h1>
      <p class="text-base-content/50 mt-2 max-w-xs text-sm leading-relaxed">
        Collect stays, stops, expenses and booking emails — all in one place.
      </p>

    </div>

  <% else %>

    <%# ── Trip cards ── %>
    <div class="grid grid-cols-1 gap-4 pb-24">
      <% @trips.each do |trip| %>
        <%= link_to trip, class: "group block rounded-3xl overflow-hidden border border-base-content/10 bg-base-200 hover:border-primary/40 hover:shadow-lg hover:shadow-black/40 transition-all duration-200" do %>

          <%# Cover image %>
          <div class="relative h-44 overflow-hidden">
            <% if (cover_src = trip_cover_src(trip)) %>
              <img src="<%= cover_src %>"
                   alt="<%= trip.title %>"
                   class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
            <% else %>
              <% gradient_colors = %w[14b8a6 7c3aed 0d9488 2563eb d97706] %>
              <div class="w-full h-full"
                   style="background: linear-gradient(135deg, #0a0f1c 0%, #<%= gradient_colors[trip.id.sum % gradient_colors.size] %> 100%)">
                <div class="w-full h-full flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
              </div>
            <% end %>

            <%# Gradient overlay + title on image %>
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 px-4 pb-3 pt-8">
              <h2 class="font-bold text-white text-base leading-tight"><%= trip.title %></h2>
              <p class="text-sm text-white/65 mt-0.5">
                <% if trip.start_date && trip.end_date %>
                  <%= trip.start_date.strftime("%b %-d") %> – <%= trip.end_date.strftime("%b %-d, %Y") %>
                <% elsif trip.start_date %>
                  From <%= trip.start_date.strftime("%b %-d, %Y") %>
                <% else %>
                  Dates TBD
                <% end %>
              </p>
            </div>

            <%# Pending inbox badge %>
            <% if trip.pending_review_count > 0 %>
              <div class="absolute top-3 right-3">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-warning/90 text-warning-content text-[11px] font-semibold">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                  </svg>
                  <%= trip.pending_review_count %> to review
                </span>
              </div>
            <% end %>
          </div>

          <%# Footer: traveller avatars + count %>
          <div class="px-4 py-3 flex items-center gap-2 border-t border-base-content/10">
            <div class="avatar-group -space-x-2 shrink-0">
              <% trip.trip_members.first(5).each do |member| %>
                <div class="avatar" title="<%= member.traveler.name %>">
                  <div class="w-7 rounded-full ring-2 ring-base-200">
                    <%= image_tag member.traveler.avatar(size: 32), alt: member.traveler.name,
                          class: "rounded-full", referrerpolicy: "no-referrer" %>
                  </div>
                </div>
              <% end %>
              <% if trip.trip_members.size > 5 %>
                <div class="avatar placeholder">
                  <div class="w-7 rounded-full bg-base-300 text-base-content/60 ring-2 ring-base-200 text-xs">
                    <span>+<%= trip.trip_members.size - 5 %></span>
                  </div>
                </div>
              <% end %>
            </div>
            <span class="text-xs text-base-content/40 ml-auto">
              <%= trip.trip_members.size == 1 ? "Solo" : "#{trip.trip_members.size} travellers" %>
            </span>
            <%# Chevron %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/20 group-hover:text-primary/60 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </div>

        <% end %>
      <% end %>
    </div>

    <%== series_nav(@pagy) if @pagy.pages > 1 %>

  <% end %>

</div>
