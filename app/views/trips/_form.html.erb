<%= form_with model: trip, class: "space-y-4" do |f| %>
  <% if trip.errors.any? %>
    <div class="alert alert-error">
      <ul><% trip.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %></ul>
    </div>
  <% end %>

  <div class="form-control">
    <%= f.label :title, class: "label" %>
    <%= f.text_field :title, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control">
    <%= f.label :description, class: "label" %>
    <%= f.text_area :description, rows: 3, class: "textarea textarea-bordered w-full" %>
  </div>

  <div class="grid grid-cols-2 gap-4" data-controller="date-range">
    <div class="form-control">
      <%= f.label :start_date, class: "label" %>
      <%= f.date_field :start_date, class: "input input-bordered w-full",
            data: { date_range_target: "start", action: "change->date-range#startChanged" } %>
    </div>
    <div class="form-control">
      <%= f.label :end_date, class: "label" %>
      <%= f.date_field :end_date, class: "input input-bordered w-full",
            data: { date_range_target: "end" } %>
    </div>
  </div>

  <div class="flex gap-3 mt-6">
    <%= f.submit trip.new_record? ? "Create Trip" : "Save Changes", class: "btn btn-primary" %>
    <%= link_to "Cancel", trip.new_record? ? trips_path : trip, class: "btn btn-outline" %>
  </div>
<% end %>
