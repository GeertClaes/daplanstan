<%# Hide global navbar — the card IS the screen %>
<% content_for :hide_navbar, true %>
<% content_for :main_class, "flex flex-col overflow-hidden" %>

<%# ── Nav band ── %>
<div class="h-14 shrink-0 max-w-sm mx-auto w-full px-4 flex items-center">
</div>

<%# ── Card ── %>
<div class="flex-1 min-h-0 px-4 pb-4">
  <div class="max-w-sm mx-auto h-full bg-base-200 border border-base-content/10 rounded-3xl
              overflow-visible flex flex-col">

    <%# ── TOP: trip name ── %>
    <div class="px-5 pt-5 pb-4 shrink-0">
      <p class="text-2xl font-bold text-base-content leading-tight"><%= @trip.title %></p>
    </div>

    <%# ── PERFORATION 1 ── %>
    <div class="relative flex items-center h-5 shrink-0">
      <div class="absolute -left-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
      <div class="flex-1 border-t-2 border-dashed border-base-content/15 mx-3"></div>
      <div class="absolute -right-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
    </div>

    <%# ── MIDDLE: current photo + actions ── %>
    <div class="flex-1 min-h-0 overflow-y-auto px-5 py-4 flex flex-col gap-5">

      <%# Current photo %>
      <% cover_src = trip_cover_src(@trip) %>
      <% if cover_src %>
        <div class="w-full aspect-video rounded-2xl overflow-hidden border border-base-content/10 shadow-md">
          <img src="<%= cover_src %>" alt="<%= @trip.title %>"
               class="w-full h-full object-cover">
        </div>
      <% else %>
        <div class="w-full aspect-video rounded-2xl border border-dashed border-base-content/15
                    flex items-center justify-center">
          <div class="text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-base-content/20 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="text-sm text-base-content/30">No cover photo yet</p>
          </div>
        </div>
      <% end %>

      <%# Upload a custom photo %>
      <div class="flex flex-col gap-2">
        <p class="dp-label">Upload a photo</p>
        <%= form_with url: update_cover_trip_path(@trip), method: :patch, multipart: true do |f| %>
          <label class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-base-300/20 border border-base-content/5
                        hover:bg-primary/10 hover:border-primary/20 transition-colors cursor-pointer group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 text-base-content/40 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
            </svg>
            <span class="text-sm text-base-content/60 group-hover:text-base-content transition-colors">Choose from your photos…</span>
            <%= f.file_field :cover_image, accept: "image/*",
                  class: "sr-only",
                  onchange: "this.form.submit()" %>
          </label>
        <% end %>
      </div>

      <%# Fetch from Pexels %>
      <div class="flex flex-col gap-2">
        <p class="dp-label">Fetch from Pexels</p>
        <%= button_to refresh_cover_trip_path(@trip), method: :post,
              class: "flex items-center gap-3 w-full px-3 py-2.5 rounded-xl bg-base-300/20 border border-base-content/5
                      hover:bg-primary/10 hover:border-primary/20 transition-colors text-left group" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 text-base-content/40 group-hover:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          <span class="text-sm text-base-content/60 group-hover:text-base-content transition-colors">Find a photo for "<%= @trip.title %>"</span>
        <% end %>
      </div>

    </div>

    <%# ── PERFORATION 2 ── %>
    <div class="relative flex items-center h-5 shrink-0">
      <div class="absolute -left-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
      <div class="flex-1 border-t-2 border-dashed border-base-content/15 mx-3"></div>
      <div class="absolute -right-2.5 w-5 h-5 rounded-full bg-base-100 z-10 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]"></div>
    </div>

    <%# ── BOTTOM: back ── %>
    <div class="px-5 py-4 shrink-0 flex items-center">

      <%= link_to trip_path(@trip, tab: "trip"),
            class: "w-12 h-12 rounded-full bg-base-300/80 text-base-content/50
                    hover:text-base-content hover:bg-base-300 transition-colors
                    flex items-center justify-center",
            data: { turbo_direction: "back" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      <% end %>

    </div>

  </div>
</div>
