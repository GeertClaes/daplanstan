<% content_for :main_class, "overflow-y-auto py-8" %>

<div class="max-w-2xl mx-auto px-4">
  <div class="bg-neutral-800 rounded-2xl overflow-hidden shadow-[0_8px_40px_rgba(0,0,0,0.4)]">

    <div class="px-5 py-5 border-b border-neutral-700">
      <p class="text-[10px] font-mono uppercase tracking-widest text-neutral-600 mb-1">Beta Invites</p>
      <p class="text-xs text-neutral-500">Share invite links with people you want to give beta access. Each link can only be used once.</p>
    </div>

    <%# ── Invite list ── %>
    <% if @invites.any? %>
      <% @invites.each do |invite| %>
        <div class="flex items-start gap-4 px-5 py-4 border-b border-neutral-700/40 last:border-b-0">
          <div class="flex-1 min-w-0">
            <% if invite.note.present? %>
              <p class="text-sm font-medium text-neutral-200 truncate"><%= invite.note %></p>
            <% end %>
            <% if invite.email.present? %>
              <p class="text-xs text-neutral-500 mt-0.5">Restricted to <%= invite.email %></p>
            <% end %>

            <div class="flex items-center gap-2 mt-2 bg-neutral-900/60 rounded-lg px-3 py-2">
              <p class="font-mono text-xs text-neutral-400 flex-1 truncate select-all">
                <%= accept_invite_url(invite.token) %>
              </p>
              <button type="button"
                      class="text-xs text-primary hover:underline shrink-0 whitespace-nowrap"
                      onclick="navigator.clipboard.writeText('<%= accept_invite_url(invite.token) %>'); this.textContent='Copied!'; setTimeout(()=>this.textContent='Copy',2000)">
                Copy
              </button>
            </div>
          </div>

          <div class="flex flex-col items-end gap-2 shrink-0">
            <% if invite.used? %>
              <span class="text-[10px] font-semibold uppercase tracking-wide text-emerald-500">Used</span>
              <p class="text-[10px] text-neutral-600"><%= invite.used_by&.name %></p>
            <% elsif invite.expired? %>
              <span class="text-[10px] font-semibold uppercase tracking-wide text-amber-600">Expired</span>
            <% else %>
              <span class="text-[10px] font-semibold uppercase tracking-wide text-primary">Pending</span>
              <%= button_to settings_invite_path(invite), method: :delete,
                    class: "text-[10px] text-neutral-600 hover:text-red-400 transition-colors",
                    data: { turbo_confirm: "Revoke this invite?" } do %>
                Revoke
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="px-5 py-10 text-center">
        <p class="text-sm text-neutral-600">No invites yet.</p>
      </div>
    <% end %>

    <%# ── New invite form ── %>
    <div class="px-5 py-5 bg-neutral-900/40 border-t border-neutral-700">
      <p class="text-[10px] font-mono uppercase tracking-widest text-neutral-600 mb-3">Create invite</p>
      <%= form_with url: settings_invites_path, class: "space-y-3" do |f| %>
        <div class="flex gap-2">
          <%= f.text_field :note, placeholder: "Label (e.g. \"for Sarah\")",
                class: "input flex-1 bg-neutral-800 border border-neutral-700 rounded-lg text-neutral-200 placeholder:text-neutral-700 text-sm focus:outline-none focus:border-primary px-3 py-2 h-9 min-h-0" %>
          <%= f.email_field :email, placeholder: "Restrict to email (optional)",
                class: "input flex-1 bg-neutral-800 border border-neutral-700 rounded-lg text-neutral-200 placeholder:text-neutral-700 text-sm focus:outline-none focus:border-primary px-3 py-2 h-9 min-h-0" %>
          <%= f.submit "Generate", class: "btn btn-primary btn-sm h-9 min-h-0 shrink-0" %>
        </div>
        <p class="text-[11px] text-neutral-700">Leave email blank to create a generic link anyone can use.</p>
      <% end %>
    </div>

    <div class="px-5 py-4 border-t border-neutral-700">
      <%= link_to "← Back to settings", settings_path, class: "text-xs text-neutral-500 hover:text-neutral-300" %>
    </div>

  </div>
</div>
