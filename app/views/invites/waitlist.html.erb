<% content_for :main_class, "flex items-center justify-center py-16 px-4" %>

<div class="max-w-sm w-full text-center">
  <div class="w-16 h-16 rounded-full bg-neutral-800 border border-neutral-700 flex items-center justify-center mx-auto mb-6">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
    </svg>
  </div>

  <h1 class="text-xl font-bold text-neutral-100 mb-2">Invite only</h1>
  <p class="text-sm text-neutral-500 mb-8 leading-relaxed">
    Daplanstan is currently in private beta.<br>
    Ask someone who's already using it to send you an invite link.
  </p>

  <% if flash[:alert] %>
    <div class="alert alert-warning text-sm mb-4">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <p class="text-xs text-neutral-700">Already have an invite? Click the link in your invite email.</p>
</div>
