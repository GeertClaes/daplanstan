<% content_for :hide_navbar, true %>
<% content_for :main_class, "overflow-y-auto" %>

<%# ── Close bar ── %>
<div class="sticky top-0 z-10 dp-nav-bar border-b px-4 py-3 flex items-center justify-between shrink-0">
  <span class="text-base font-semibold text-base-content">Settings</span>
  <%= link_to settings_back_path,
        class: "w-9 h-9 rounded-full flex items-center justify-center
                text-base-content/50 hover:text-base-content hover:bg-base-300/60
                transition-colors",
        data: { turbo_direction: "back" } do %>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  <% end %>
</div>

<div class="max-w-sm mx-auto px-4 space-y-3 py-6">

  <%# ── Profile card ── %>
  <div class="dp-card overflow-hidden">

    <div class="px-5 pt-5 pb-4 flex items-center gap-4">
      <%= image_tag current_user.avatar(size: 96), alt: current_user.name,
            class: "w-14 h-14 rounded-full object-cover shrink-0 ring-2 ring-base-content/10",
            referrerpolicy: "no-referrer" %>
      <div class="min-w-0">
        <p class="font-bold text-base-content truncate"><%= current_user.name %></p>
        <p class="text-xs text-base-content/40 truncate mt-0.5"><%= current_user.email %></p>
      </div>
    </div>

    <div class="px-5 pb-5">
      <p class="dp-label mb-2">Display name</p>
      <%= form_with model: current_user, url: settings_path, method: :patch,
            class: "flex gap-2 items-center" do |f| %>
        <%= f.text_field :name,
              class: "flex-1 text-sm text-base-content bg-transparent
                      border-0 border-b border-base-content/15 rounded-none px-0 pb-2
                      focus:outline-none focus:border-primary placeholder:text-base-content/25" %>
        <%= f.submit "Save", class: "btn btn-primary btn-xs h-8 min-h-0 shrink-0" %>
      <% end %>
    </div>

  </div>

  <%# ── Travellers ── %>
  <div class="dp-card overflow-hidden">

    <div class="px-5 pt-5 pb-3 flex items-center justify-between">
      <div>
        <p class="dp-label">Account members</p>
        <p class="text-xs text-base-content/40 mt-0.5">People you travel with</p>
      </div>
      <% if @travelers.any? %>
        <span class="text-xs font-semibold text-base-content/40"><%= @travelers.size %></span>
      <% end %>
    </div>

    <% if @travelers.any? %>
      <% @travelers.each do |traveler| %>
        <% is_owner = traveler.user_id == @account.owner_id %>
        <div class="flex items-center gap-3 px-5 py-3 border-t border-base-content/5 hover:bg-base-300/20 transition-colors">
          <% if traveler.pending? %>
            <div class="w-9 h-9 rounded-full bg-base-300/60 border border-dashed border-base-content/20 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-base-content/30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
          <% elsif traveler.managed? %>
            <div class="w-9 h-9 rounded-full bg-base-300/60 flex items-center justify-center shrink-0 text-base-content/50 font-semibold text-sm">
              <%= traveler.name.first.upcase %>
            </div>
          <% else %>
            <%= image_tag traveler.avatar(size: 64), alt: traveler.name,
                  class: "w-9 h-9 rounded-full object-cover shrink-0 ring-2 ring-base-content/10",
                  referrerpolicy: "no-referrer" %>
          <% end %>

          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-base-content truncate"><%= traveler.name %></p>
            <% if traveler.pending? %>
              <p class="text-xs text-warning/70 mt-0.5">Invite pending</p>
            <% elsif traveler.managed? %>
              <p class="text-xs text-base-content/30 mt-0.5">No login</p>
            <% else %>
              <p class="text-xs text-base-content/40 truncate mt-0.5"><%= traveler.display_email %></p>
            <% end %>
          </div>

          <div class="shrink-0">
            <% if is_owner %>
              <span class="text-[10px] font-bold uppercase tracking-wide text-primary/60">Owner</span>
            <% else %>
              <%= button_to settings_traveler_path(traveler), method: :delete,
                    class: "w-7 h-7 rounded-full flex items-center justify-center text-base-content/30
                            hover:text-error hover:bg-error/10 transition-colors",
                    data: { turbo_confirm: "Remove #{traveler.name} from your account?" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="px-5 py-8 text-center border-t border-base-content/5">
        <p class="text-sm text-base-content/30">No members yet</p>
        <p class="text-xs text-base-content/20 mt-0.5">Add people you travel with below</p>
      </div>
    <% end %>

    <%# Add member form %>
    <div class="px-5 py-4 border-t border-base-content/5 bg-base-300/10">
      <p class="dp-label mb-2">Add member</p>
      <%= form_with url: settings_travelers_path, class: "flex gap-2" do |f| %>
        <%= f.text_field :name, placeholder: "Name",
              class: "input w-28 bg-base-200 border border-base-content/10 rounded-xl text-sm h-9 min-h-0
                      focus:outline-none focus:border-primary px-3" %>
        <%= f.email_field :email, placeholder: "Email (optional)",
              class: "input flex-1 bg-base-200 border border-base-content/10 rounded-xl text-sm h-9 min-h-0
                      focus:outline-none focus:border-primary px-3" %>
        <%= f.submit "Add", class: "btn btn-primary btn-sm h-9 min-h-0 shrink-0" %>
      <% end %>
      <p class="text-[11px] text-base-content/25 mt-1.5">With an email they'll get an invite. Without: name-only.</p>
    </div>

  </div>

  <%# ── Linked accounts ── %>
  <div class="dp-card overflow-hidden px-5 py-5">
    <p class="dp-label mb-3">Linked accounts</p>

    <% if @identities.any? %>
      <div class="space-y-2">
        <% @identities.each do |identity| %>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-base-300/60 flex items-center justify-center shrink-0">
              <% if identity.provider == "google_oauth2" %>
                <svg class="h-4 w-4 text-base-content/50" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
              <% else %>
                <svg class="h-4 w-4 text-base-content/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-base-content">
                <%= identity.provider == "google_oauth2" ? "Google" : identity.provider.capitalize %>
              </p>
              <p class="text-xs text-base-content/40 truncate"><%= identity.provider_email.presence || identity.provider_uid %></p>
            </div>
            <span class="text-[10px] font-semibold text-success tracking-wide">Connected</span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-base-content/30">No linked accounts.</p>
    <% end %>
  </div>

  <%# ── Sign out + danger ── %>
  <div class="dp-card overflow-hidden">
    <div class="px-5 py-4 flex items-center justify-between">
      <div>
        <p class="dp-label mb-0.5">Signed in as</p>
        <p class="text-sm font-medium text-base-content"><%= current_user.email %></p>
      </div>
      <%= link_to "Sign out", sign_out_path, method: :delete,
            class: "btn btn-sm btn-outline",
            data: { turbo_method: :delete } %>
    </div>
    <div class="px-5 pb-5 border-t border-base-content/5">
      <p class="dp-label mb-2 mt-4">Danger zone</p>
      <button class="btn btn-error btn-outline btn-sm w-full opacity-40" disabled>Delete account (coming soon)</button>
    </div>
  </div>

  <%# ── Appearance ── %>
  <div class="dp-card overflow-hidden">
    <div class="px-5 pt-5 pb-4">
      <p class="dp-label mb-4">Appearance</p>

      <%
        themes = [
          { key: "stan",       label: "Stan",       bg: "#141f32",   card: "#1a2840",   accent: "#d4a017" },
          { key: "midnight",   label: "Midnight",   bg: "#0d1220",   card: "#13192e",   accent: "#22cbb2" },
          { key: "dusk",       label: "Dusk",       bg: "#1e1410",   card: "#271b13",   accent: "#d4931a" },
          { key: "graphite",   label: "Graphite",   bg: "#282829",   card: "#363638",   accent: "#22cbb2" },
          { key: "sand",       label: "Sand",       bg: "#f8f4ee",   card: "#eee7dc",   accent: "#0d8f80" },
          { key: "andromeda",  label: "Andromeda",  bg: "#23262e",   card: "#2d313b",   accent: "#00e8c6" },
          { key: "ayudark",    label: "Ayu Dark",   bg: "#10121d",   card: "#20232f",   accent: "#e39f4c" },
          { key: "catppuccin", label: "Catppuccin", bg: "#181825",   card: "#1e1e2e",   accent: "#89b4fa" },
          { key: "everforest", label: "Everforest", bg: "#1e2326",   card: "#272e33",   accent: "#7fbbb3" },
          { key: "flexoki",    label: "Flexoki",    bg: "#100f0f",   card: "#1c1b1a",   accent: "#399d94" },
          { key: "githubdark", label: "GH Dark",    bg: "#0f1317",   card: "#161b22",   accent: "#36b4be" },
          { key: "githublight",label: "GH Light",   bg: "#e7e9ec",   card: "#dadee3",   accent: "#1067ce" },
          { key: "gruvbox",    label: "Gruvbox",    bg: "#282828",   card: "#1d2021",   accent: "#d3869b" },
          { key: "kanagawa",   label: "Kanagawa",   bg: "#191823",   card: "#22212f",   accent: "#7a92cc" },
          { key: "monokai",    label: "Monokai",    bg: "#2e2e2e",   card: "#292825",   accent: "#b05279" },
          { key: "nightfox",   label: "Nightfox",   bg: "#2e3040",   card: "#393946",   accent: "#62bfc4" },
          { key: "nightowl",   label: "Night Owl",  bg: "#1d2b3a",   card: "#091b2f",   accent: "#789beb" },
          { key: "onedarkpro", label: "One Dark",   bg: "#20242b",   card: "#262b33",   accent: "#61afef" },
          { key: "rosepine",   label: "Rose Pine",  bg: "#191724",   card: "#1f1d2e",   accent: "#eb6f92" },
          { key: "solarized",  label: "Solarized",  bg: "#002b36",   card: "#073642",   accent: "#2aa198" },
          { key: "tokyonight", label: "Tokyo Night",bg: "#16161e",   card: "#121218",   accent: "#7aa2f7" },
          { key: "vscode",     label: "VS Code",    bg: "#1f1f1f",   card: "#252526",   accent: "#22919a" },
        ]
        active = current_user.theme.presence || "stan"
      %>

      <div class="grid grid-cols-4 gap-2">
        <% themes.each do |t| %>
          <% selected = active == t[:key] %>
          <%= form_with model: current_user, url: settings_path(back: params[:back]), method: :patch,
                data: { turbo: false } do |f| %>
            <%= f.hidden_field :theme, value: t[:key] %>
            <button type="submit"
                    class="group w-full flex flex-col items-center gap-1.5 p-1.5 rounded-2xl transition-all
                           <%= selected ? "ring-2 ring-primary" : "ring-1 ring-base-content/10 hover:ring-primary/50" %>">
              <%# Swatch %>
              <div class="w-full rounded-xl overflow-hidden"
                   style="background:<%= t[:bg] %>; aspect-ratio:4/3">
                <div class="h-full flex flex-col justify-between p-1.5">
                  <div class="w-full h-3 rounded-md opacity-80"
                       style="background:<%= t[:card] %>"></div>
                  <div class="w-3/5 h-1.5 rounded-full self-start"
                       style="background:<%= t[:accent] %>"></div>
                </div>
              </div>
              <p class="text-[10px] font-semibold leading-none <%= selected ? "text-primary" : "text-base-content/60" %>">
                <%= t[:label] %>
              </p>
            </button>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="h-4"></div>

</div>
