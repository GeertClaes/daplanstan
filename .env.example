# ─────────────────────────────────────────────
# AI — Anthropic
# ─────────────────────────────────────────────

ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────
# Photos — Pexels (free at pexels.com/api)
# ─────────────────────────────────────────────

# Used to auto-fetch a destination cover photo when a trip is created
PEXELS_API_KEY=

# ─────────────────────────────────────────────
# Authentication — Google OAuth
# ─────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (optional)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# ─────────────────────────────────────────────
# Email — Postmark
# ─────────────────────────────────────────────

# API token for your Postmark server
POSTMARK_API_TOKEN=9c9cddc9-116b-468b-90d6-f71a24ab3df9

# Must be a verified sender signature or domain in Postmark
POSTMARK_FROM_EMAIL=

# Domain used to generate unique inbound email addresses per trip
TRIP_EMAIL_DOMAIN=whats.daplanstan.kwokah.com

# Password for the ActionMailbox inbound webhook (set in Postmark webhook URL)
RAILS_INBOUND_EMAIL_PASSWORD=

# ─────────────────────────────────────────────
# Rails
# ─────────────────────────────────────────────

# Only needed in production (dev uses config/master.key)
RAILS_MASTER_KEY=

# ─────────────────────────────────────────────
# Active Record Encryption
# ─────────────────────────────────────────────

# Generated via: rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
